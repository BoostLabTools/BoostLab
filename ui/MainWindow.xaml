<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="BoostLabWindow"
    Title="BoostLab"
    Width="1280"
    Height="820"
    MinWidth="1024"
    MinHeight="680"
    WindowStartupLocation="CenterScreen"
    Background="#0B1020"
    FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackground" Color="#0B1020" />
        <SolidColorBrush x:Key="PanelBackground" Color="#11182B" />
        <SolidColorBrush x:Key="CardBackground" Color="#182238" />
        <SolidColorBrush x:Key="BorderBrush" Color="#293653" />
        <SolidColorBrush x:Key="PrimaryText" Color="#F4F7FC" />
        <SolidColorBrush x:Key="SecondaryText" Color="#9EABC2" />
        <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#075985" />

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Margin" Value="10,3" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#22304B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ActionBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#0369A1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#0C4A6E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#10172A"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        Foreground="{StaticResource PrimaryText}"
                        FontSize="24"
                        FontWeight="Bold"
                        Text="BoostLab" />
                    <TextBlock
                        Margin="0,3,0,0"
                        Foreground="{StaticResource SecondaryText}"
                        FontSize="12"
                        Text="Windows optimization workflow" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Border Margin="4,0" Padding="10,6" Background="#17233A" CornerRadius="6">
                        <TextBlock x:Name="AdminStatusText" Foreground="{StaticResource SecondaryText}" Text="Admin: Checking" />
                    </Border>
                    <Border Margin="4,0" Padding="10,6" Background="#17233A" CornerRadius="6">
                        <TextBlock x:Name="InternetStatusText" Foreground="{StaticResource SecondaryText}" Text="Internet: Checking" />
                    </Border>
                    <Border Margin="4,0" Padding="10,6" Background="#17233A" CornerRadius="6">
                        <TextBlock x:Name="LicenseStatusText" Foreground="{StaticResource SecondaryText}" Text="License: Placeholder" />
                    </Border>
                    <Border Margin="4,0" Padding="10,6" Background="#17233A" CornerRadius="6">
                        <TextBlock x:Name="WindowsStatusText" Foreground="{StaticResource SecondaryText}" Text="Windows: Detecting" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock
                    DockPanel.Dock="Top"
                    Margin="18,22,18,10"
                    Foreground="{StaticResource SecondaryText}"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="WORKFLOW STAGES" />
                <StackPanel x:Name="StageNavigationPanel" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Margin="26,22,26,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,18">
                <TextBlock
                    x:Name="StageTitleText"
                    Foreground="{StaticResource PrimaryText}"
                    FontSize="26"
                    FontWeight="Bold"
                    Text="Check" />
                <TextBlock
                    x:Name="StageDescriptionText"
                    Margin="0,5,0,0"
                    Foreground="{StaticResource SecondaryText}"
                    FontSize="13"
                    Text="Select a workflow stage." />
            </StackPanel>

            <ScrollViewer
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="ToolCardsPanel" />
            </ScrollViewer>
        </Grid>

        <Border
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="#0F1729"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="18,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Foreground="{StaticResource PrimaryText}"
                    FontWeight="SemiBold"
                    Text="Activity Log" />
                <TextBlock
                    x:Name="ApplicationStatusText"
                    Grid.Column="1"
                    Foreground="{StaticResource AccentBrush}"
                    Text="Ready" />

                <TextBox
                    x:Name="LogTextBox"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,9,0,0"
                    Padding="10,8"
                    Background="#090E1A"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Foreground="#C9D4E8"
                    FontFamily="Consolas"
                    FontSize="12"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
    </Grid>
</Window>
